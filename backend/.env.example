# === Configuracion minima ===
# Todo lo demas (LLM provider, API keys, integraciones, origenes/destinos)
# se configura desde la UI en /config

# Base de datos SQLite
DB_PATH=data/ticketing.db

# Clave AES-256-GCM para cifrar mapas de sustitucion (dejar vacio = clave efimera)
# Generar con: python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; import base64; print(base64.b64encode(AESGCM.generate_key(256)).decode())"
ENCRYPTION_KEY=

# CORS origins permitidos
CORS_ORIGINS=["http://localhost:3000"]
