# Application
DEBUG=true
DB_PATH=data/ticketing.db

# LLM Provider: "ollama" or "azure"
LLM_PROVIDER=ollama

# Ollama (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minimax-m1:latest

# Azure OpenAI (only needed if LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Jira Source (client system) - not needed if USE_MOCK_JIRA=true
JIRA_SOURCE_URL=https://your-jira.atlassian.net
JIRA_SOURCE_TOKEN=your-jira-token
JIRA_SOURCE_EMAIL=your-email@company.com

# KOSIN (internal Jira)
KOSIN_URL=https://umane.emeal.nttdata.com/jiraito
KOSIN_TOKEN=your-kosin-bearer-token
KOSIN_PROJECT=PESESG
KOSIN_ISSUE_TYPE_ID=15408
KOSIN_BOARD_ID=18418

# Encryption (base64-encoded 32-byte key for AES-256-GCM)
# Generate with: python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; import base64; print(base64.b64encode(AESGCM.generate_key(256)).decode())"
ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Mock mode (set to false when real Jira is available)
USE_MOCK_JIRA=true
